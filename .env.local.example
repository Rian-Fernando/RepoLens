# ---- All optional. The app runs 100% free with nothing set. ----

# AI-written suggestions + README drafts (Gemini free tier: ~1,500 requests/day, no card).
# Get a free key at https://aistudio.google.com/apikey — without it, the built-in
# rules engine generates the suggestions instead.
# GEMINI_API_KEY=

# Optional model override (defaults to gemini-flash-latest, falls back to gemini-2.5-flash)
# GEMINI_MODEL=

# Server-side GitHub token — used only by the /api/badge endpoint so embedded
# badges don't exhaust the unauthenticated 60 req/hour limit. A fine-grained
# token with no extra permissions (public data) is enough.
# GITHUB_TOKEN=

# Where the "back to portfolio" links point (defaults to https://rianfernando.com).
NEXT_PUBLIC_PORTFOLIO_URL=https://rianfernando.com
